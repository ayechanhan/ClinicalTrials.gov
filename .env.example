# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- OpenAI (reasoning layer) ---
# API key provided by Cheiron via email.
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# --- ClinicalTrials.gov Data API ---
CT_API_BASE=https://clinicaltrials.gov/api/v2
# studies per page (max 1000)
CT_PAGE_SIZE=100
# safety cap on the number of pages fetched per request
CT_MAX_PAGES=10

# --- Logging ---
LOG_LEVEL=INFO
